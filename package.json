{
  "name": "@stratipy/react",
  "version": "0.1.1",
  "description": "Add an AI agent to your React app in 60 seconds",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core-export.d.ts",
        "default": "./dist/core-export.js"
      },
      "require": {
        "types": "./dist/core-export.d.cts",
        "default": "./dist/core-export.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "stratipy",
    "ai",
    "agent",
    "react",
    "hook",
    "chat",
    "sse",
    "streaming"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratipy/js"
  },
  "homepage": "https://stratipy.com"
}
